# Production .env for yesorno.plateos.site (copy values into .env on the VPS)

APP_NAME="Yes or No POS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yesorno.plateos.site

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=teboos
REVERB_APP_KEY=teboos-key
REVERB_APP_SECRET=teboos-secret
REVERB_HOST=yesorno.plateos.site
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
