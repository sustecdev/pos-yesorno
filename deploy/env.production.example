# Production .env for yesorno.plateos.site (shared hosting)

APP_NAME="Yes or No POS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://pos.yesorno.bar

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

SESSION_DRIVER=database
QUEUE_CONNECTION=sync
CACHE_STORE=database
BROADCAST_CONNECTION=log

# Reverb/WebSockets need a VPS — not available on shared hosting.
# Kitchen display polls every 5s without Reverb.
